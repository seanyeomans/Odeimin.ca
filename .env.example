# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Preferred: bcrypt/argon hash from password_hash().
# Generate one with:
# php -r "echo password_hash('change-me', PASSWORD_DEFAULT), PHP_EOL;"
# Wrap hash in single quotes so Docker Compose treats $ as literal characters.
ADMIN_PASSWORD_HASH=''

# Optional fallback for legacy setups only (avoid in production).
# UPLOAD_PASSWORD=change-me

MAX_SIZE_MB=20
ADMIN_SESSION_TTL=900
ADMIN_LOGIN_WINDOW=900
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT=900
